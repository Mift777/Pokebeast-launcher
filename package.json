{
    "name": "Pokebeast-launcher",
    "preductname": "Pokebeast Launcher",
    "version": "2.2.2",
    "description": "Launcher Minecraft para o servidor Pokebeast",
    "main": "src/app.js",
    "author": {
        "name": "Mift777",
        "email": "private",
        "url": "https://github.com/Mift777"
    },
    "url": "http://pokebeast.infinityfreeapp.com/htdocs/launcher",
    "scripts": {
        "start": "cross-env-shell NODE_ENV=dev electron .",
        "dev": "cross-env-shell DEV_TOOL=open nodemon --exec npm start",
        "build": "node build.js --obf=true --build=platform",
        "icon": "node build.js --icon"
    },
    "license": "CCANC",
    "nodemonConfig": {
        "ext": "js,html,css",
        "ignore": "**/test"
    },
    "dependencies": {
        "electron-store": "^8.2.0",
        "electron-updater": "^6.7.3",
        "minecraft-java-core": "^4.2.5",
        "node-fetch": "^2.7.0",
        "xml-js": "^1.6.11"
    },
    "devDependencies": {
        "cross-env": "^10.1.0",
        "electron": "^40.0.0",
        "electron-builder": "^26.0.12",
        "javascript-obfuscator": "^5.1.0",
        "jimp": "^1.6.0",
        "nodemon": "^3.1.11",
        "png2icons": "^2.0.1"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Mift777/Pokebeast-launcher.git"
    }
}
